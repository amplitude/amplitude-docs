          "[Amplitude] Hierarchy",
          "[Amplitude] Screen Name"
        ]
      },
      "[Amplitude] Rage Click": {
        "properties": [
          "[Amplitude] Begin Time",
          "[Amplitude] End Time",
          "[Amplitude] Duration",
          "[Amplitude] Click Count",
          "[Amplitude] Clicks",
